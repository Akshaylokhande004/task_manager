{
  "include": ["src/**/*"],
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "commonjs",
    "target": "ES6",
    "moduleResolution": "node",

    "types": ["node"],
    "esModuleInterop": true,

    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0"
  }
}